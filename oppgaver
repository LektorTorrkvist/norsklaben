    "tags": ["verb", "bokmålsoverføring"]
  },
  {
    "id": "OPG-202",
    "type": "multiple_choice",
    "kompetanse": ["substantiv: kjønn og bestemte former"],
    "vanskegrad": 2,
    "spørsmål": "Kva er korrekt bestemt form eintal av «ei oppgåve» på nynorsk?",
