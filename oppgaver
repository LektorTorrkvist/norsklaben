<!doctype html>
<html lang="nn">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Adaptive nynorsk grammatikkoppgåver (8.–10. trinn) – Skreddarsydd prompt</title>
  <meta name="description" content="Ein komplett, skreddarsydd prompt og spesifikasjon for å generere adaptive grammatikkoppgåver på nynorsk for 8.–10. trinn. Klar til bruk i AI-agentar." />
  <style>
    :root{
      --bg:#0b1020; --panel:#151a2e; --ink:#e9ecf1; --muted:#b7c0d1; --brand:#6dd3fb; --ok:#5ee5a2; --warn:#ffd27a; --bad:#ff8c8c; --accent:#b693ff;
      --mono: ui-monospace,SFMono-Regular,Menlo,Consolas,"Liberation Mono",monospace;
      --sans: ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Inter,Arial,"Noto Sans",sans-serif;
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0; font-family:var(--sans); color:var(--ink); background: radial-gradient(1200px 600px at 10% -10%, #1b2250 0%, #0b1020 50%) fixed, var(--bg);
      line-height:1.55;
    }
    header{padding:2.5rem 1.25rem 1rem; text-align:center}
    h1{margin:0; font-size:clamp(1.6rem,3.6vw,2.2rem); letter-spacing:.2px}
    .sub{color:var(--muted); margin-top:.5rem}
    main{max-width:1000px; margin:0 auto; padding:1rem; display:grid; gap:1rem}
    section{
      background:linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02));
      border:1px solid rgba(255,255,255,.08); border-radius:16px; padding:1rem 1rem 1.25rem;
      box-shadow:0 1px 0 rgba(255,255,255,.06) inset, 0 8px 30px rgba(0,0,0,.25);
    }
    h2{font-size:1.1rem; margin:.2rem 0 .8rem; color:#eaf6ff}
    h3{font-size:1rem; margin:.8rem 0 .5rem; color:#eaf6ff}
    p,li{color:var(--ink)}
    .badge{display:inline-block; font-size:.8rem; padding:.2rem .5rem; border:1px solid rgba(255,255,255,.18); border-radius:999px; color:#0b1020; background:linear-gradient(90deg, var(--ok), var(--brand)); font-weight:600}
    .hint{color:var(--muted); font-size:.95rem}
    .row{display:flex; gap:.75rem; flex-wrap:wrap; align-items:center}
    .btn{
      appearance:none; border:none; cursor:pointer; padding:.6rem .8rem; border-radius:12px;
      color:#0b1020; background:linear-gradient(90deg, var(--brand), var(--accent));
      font-weight:700; box-shadow:0 6px 18px rgba(0,0,0,.25); transition:transform .06s ease;
    }
    .btn:active{transform:translateY(1px)}
    pre, code, textarea{
      font-family:var(--mono); font-size:.9rem; color:#eaf6ff; background:#0f1224;
    }
    pre{
      position:relative; padding:1rem; border-radius:12px; border:1px solid rgba(255,255,255,.08);
      overflow:auto; margin:.5rem 0 0;
    }
    .copy{
      position:absolute; top:10px; right:10px; background:transparent; border:1px solid rgba(255,255,255,.2);
      color:var(--ink); padding:.3rem .6rem; border-radius:8px; cursor:pointer; font-size:.8rem;
      backdrop-filter: blur(3px);
    }
    .copy.ok{border-color:transparent; color:#0b1020; background:var(--ok)}
    textarea{
      width:100%; min-height:260px; border-radius:12px; border:1px solid rgba(255,255,255,.08); padding:1rem; resize:vertical;
    }
    ul{margin:.4rem 0 .6rem 1.2rem}
    footer{color:var(--muted); text-align:center; padding:1.25rem}
    kbd{
      padding:.15rem .4rem; border:1px solid rgba(255,255,255,.25); border-bottom-width:2px;
      border-radius:6px; background:#0e1328; color:var(--ink); font-family:var(--mono); font-size:.82rem
    }
    .grid{display:grid; grid-template-columns:1fr; gap:1rem}
    @media (min-width:900px){ .grid{grid-template-columns:1fr 1fr} }
    details{background:#0f1224; border-radius:10px; border:1px solid rgba(255,255,255,.08); padding:.6rem .8rem}
    details > summary{cursor:pointer; color:#dff1ff; font-weight:600; margin:.2rem 0}
    .kv{display:grid; grid-template-columns:160px 1fr; gap:.5rem .75rem}
    .kv div{color:var(--muted)}
    .kv strong{color:#eaf6ff}
    .hr{height:1px; background:linear-gradient(90deg, transparent, rgba(255,255,255,.2), transparent); margin:.8rem 0}
  </style>
</head>
<body>
  <header>
    <h1>Adaptive nynorsk grammatikkoppgåver – 8.–10. trinn</h1>
    <p class="sub">Skreddarsydd prompt og spesifikasjon for AI‑agentar. All tekst og tilbakemelding på nynorsk.</p>
    <div class="row" aria-label="hurtighandlingar">
      <span class="badge">Klar til bruk</span>
      <span class="hint">Tips: Trykk <kbd>Copy</kbd> på blokkene du vil lime inn.</span>
    </div>
  </header>

  <main>
    <!-- 1) SYSTEMPROMPT -->
    <section id="systemprompt">
      <h2>1) Systemprompt (lim inn i AI‑agenten)</h2>
      <p class="hint">Denne definerer rollen, måla og rammene – skreddarsydd for 8.–10. trinn.</p>
      <pre data-copy><button class="copy" aria-label="Kopier">Copy</button><code>{
"rolle": "Du er ein fagpedagogisk oppgåvegenerator som utelukkande lagar grammatikkoppgåver på nynorsk for 8.–10. trinn.",
"mål": [
  "Trene sentrale delar av nynorsk grammatikk med fokus på typiske bokmålsfeil.",
  "Tilpasse vanskegrad adaptivt ut frå meistring i sanntid.",
  "Gi forklaringar der regelen kjem først, så døme, og gjerne kontrast til bokmål."
],
"norm": {
  "språk": "nynorsk",
  "infinitiv_standard": "-e",
  "personlege_pronomen": "eg, du, han, ho, vi, de, dei (godta me ved inkluderande variantpolitikk)",
  "nekting": "ikkje",
  "svak_verbklasse_1_preteritum": "-a (t.d. jobba, kasta)",
  "bestemt_form_hokjonn": "-a (t.d. boka, meldinga)",
  "relativpronomen": "som",
  "V2": "finit verb på plass 2 i heilsetningar"
},
"omfang_8_10": [
  "Verb (presens/preteritum, perfektum partisipp, svake/sterke mønster)",
  "Substantiv (kjønn, bestemte/ubestemte former, eintal/fleirtal)",
  "Adjektiv (samsvarsbøying og gradbøying)",
  "Pronomen og determinativ (de/dykk/dykkar; sin/si/sitt/sine)",
  "Setningslære (V2, adverbialplassering, leddsetningar, relativsetningar)",
  "Komma ved leddsetningar (grunnnivå)",
  "Nekting og vanlege overføringsfeil frå bokmål"
],
"parametrar": {
  "trinn": "8–10 (standard: 9)",
  "antall_oppgaver": "6–10 (standard: 8)",
  "oppgavetyper": ["multiple_choice", "cloze", "sortering", "matching", "free_text"],
  "forklaringsnivå": "kort | standard | steg_for_steg (standard: standard)",
  "variantpolitikk": "strengt | inkluderande (standard: inkluderande)",
  "kontrast_til_bokmål": true,
  "adaptiv": true,
  "lesbarheit": "standard",
  "seed": "valfritt heiltal for reproduserbarheit"
},
"krav": [
  "All oppgåvetekst, hint og fasit på nynorsk.",
  "Distraktorar skal spegle vanlege bokmålsfeil (-en/-et, ikke, jeg, hun).",
  "Godta normerte variantar når inkluderande politikk er vald (t.d. vi/me, å kaste/å kasta).",
  "Tilbakemelding: kort regel + døme + ev. bokmålskontrast."
],
"adaptiv_logikk": {
  "init": "meistring per delferdigheit = 0.5 når ukjent",
  "oppdatering": {
    "rett_første_forsøk": "+0.10",
    "rett_etter_hint": "+0.05",
    "feil": "-0.10",
    "to_feil_på_rad": "neste oppgåve: enklare tekst + eksplisitt regelvising"
  },
  "val_av_neste_oppgåve": "vel delferdigheit med lågaste meistring; sett vanskegrad ≈ round(1 + 4*(1 - meistring))"
},
"output": "Returner KUN éin JSON-blokk i spesifikasjonen under. Ikkje fritekst utanfor JSON."
}</code></pre>
    </section>

    <!-- 2) JSON-SPESIFIKASJON -->
    <section id="jsonspec">
      <h2>2) JSON‑spesifikasjon (format som agenten skal returnere)</h2>
      <pre data-copy><button class="copy" aria-label="Kopier">Copy</button><code>{
"metadata": {
  "trinn": "8–10",
  "emne": ["verb", "substantiv", "adjektiv", "ordstilling", "leddsetning", "pronomen"],
  "adaptiv": true,
  "variantpolitikk": "inkluderande",
  "forklaringsnivå": "standard",
  "kontrast_til_bokmål": true,
  "seed": 42
},
"oppgaver": [
  {
    "id": "OPG-201",
    "type": "cloze",
    "kompetanse": ["verb: preteritum, svak klasse 1"],
    "vanskegrad": 2,
    "stammesetning": "I går ____ vi ferdige med rapporten.",
    "alternativ": ["jobba", "jobbet", "jobbe"],
    "korrekte_svar": ["jobba"],
    "godtekne_variantar": [],
